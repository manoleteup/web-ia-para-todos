---
import "../styles/global.css";
import { CONTACT } from "../data/site.js";
import { absoluteUrl } from "../utils/url";
import favicon from "../assets/favicon.ico";

const {
  title = "IA Para Todos LATAM | Inteligencia Artificial Simple y Real",
  description = "IA Para Todos LATAM es un ecosistema de aprendizaje que acerca la Inteligencia Artificial a personas, comunidades, instituciones y niños de forma simple, humana y responsable.",
  canonical = absoluteUrl(CONTACT.siteUrl, "/"),
  ogUrl = canonical,
  ogTitle = "IA Para Todos LATAM",
  ogDescription = "IA Para Todos LATAM es un ecosistema de aprendizaje que acerca la Inteligencia Artificial a personas, comunidades, instituciones y niños de forma simple, humana y responsable.",
  ogImage = absoluteUrl(CONTACT.siteUrl, "/og-image.jpg"),
} = Astro.props;

const faviconHref = typeof favicon === "string" ? favicon : (favicon as { src: string }).src;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#030712" />
    <link rel="icon" href={faviconHref} sizes="any" />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
    />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
  </head>
  <body class="bg-night text-paper antialiased">
    <slot />
  </body>
</html>
