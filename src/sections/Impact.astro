---
import { BookOpen, HeartHandshake, Lightbulb, Users } from "lucide-astro";
import SectionHeading from "../components/SectionHeading.astro";
import { socialImpactItems } from "../data/site.js";

const iconByTitle = {
  "Brecha de conocimiento": BookOpen,
  "Nuevas oportunidades": Lightbulb,
  "Educación y comunidad": Users,
  "Uso responsable": HeartHandshake,
};
---

<section id="sociedad" class="section-pad bg-slateDeep/60">
  <div class="container-page">
    <div data-reveal>
      <SectionHeading
        eyebrow="IA y sociedad en Latinoamérica"
        title="La IA ya está cambiando nuestra sociedad"
      >
        <p>
          En Latinoamérica, el desafío no es solo acceder a nuevas tecnologías,
          sino comprenderlas, usarlas con criterio y ponerlas al servicio de las
          personas.
        </p>
      </SectionHeading>
    </div>
    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        socialImpactItems.map(({ title, description }, i) => {
          const Icon = iconByTitle[title as keyof typeof iconByTitle] ?? Lightbulb;

          return (
            <div
              class="rounded-3xl border border-slate-400/20 bg-cardSurface/70 p-6 transition duration-300 hover:-translate-y-1 hover:border-brandSky/35 hover:shadow-glow"
              data-reveal
              style={`transition-delay: ${i * 80}ms`}
            >
              <span class="mb-8 grid h-14 w-14 place-items-center rounded-2xl bg-cyan-300/10 text-brandCyan ring-1 ring-cyan-300/20">
                <Icon size={26} stroke-width={1.8} />
              </span>
              <h3 class="text-2xl font-black text-white">{title}</h3>
              <p class="mt-3 leading-7 text-slate-400">{description}</p>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
