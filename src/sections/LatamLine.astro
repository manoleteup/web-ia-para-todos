---
import { BookOpen, GraduationCap, HeartHandshake } from "lucide-astro";
import SectionHeading from "../components/SectionHeading.astro";
import { adultLineItems } from "../data/site.js";

const iconByTitle: Record<string, typeof BookOpen> = {
  Talleres: GraduationCap,
  "Programa Social": HeartHandshake,
  "Libro y cursos": BookOpen,
};
---

<section id="ia-para-todos" class="section-pad bg-night">
  <div class="container-page">
    <div data-reveal>
      <SectionHeading
        eyebrow="IA Para Todos LATAM"
        title="Talleres, programa social, libro y cursos"
        align="center"
      >
        <p>Formación para personas, comunidades e instituciones en toda Latinoamérica.</p>
      </SectionHeading>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-3">
      {
        adultLineItems.map((item, i) => {
          const Icon = iconByTitle[item.title] ?? BookOpen;

          return (
            <article
              class="rounded-3xl border border-slate-400/20 bg-cardSurface/70 p-6 transition duration-300 hover:-translate-y-1 hover:border-brandSky/35 hover:shadow-glow"
              data-reveal
              style={`transition-delay: ${i * 90}ms`}
            >
              <span class="mb-7 grid h-12 w-12 place-items-center rounded-2xl bg-cyan-300/10 text-cyan-100 ring-1 ring-cyan-100/20">
                <Icon size={22} stroke-width={1.8} />
              </span>
              <h3 class="text-2xl font-black text-white">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-300">{item.description}</p>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
