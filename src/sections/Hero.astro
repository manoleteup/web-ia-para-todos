---
import { Image } from "astro:assets";
import heroImage from "../assets/hero-comunidad-ia.webp";
import { heroContent } from "../data/site.js";
import { withBase } from "../utils/url";
import { HeartHandshake, Lightbulb, Users } from "lucide-astro";

const kidsHref = withBase("/kids/");

const heroCards = [
  {
    label: "Enfoque humano y cercano",
    Icon: HeartHandshake,
  },
  {
    label: "Aprendizaje simple y aplicable",
    Icon: Lightbulb,
  },
  {
    label: "Impacto social y educativo",
    Icon: Users,
  },
];
---

<section
  id="inicio"
  class="relative min-h-screen overflow-hidden bg-night pt-28"
>
  <div class="absolute inset-0 bg-gradient-to-b from-slateDeep/60 via-night to-night"></div>
  <Image
    class="hero-drift absolute inset-0 h-full w-full object-cover opacity-30"
    src={heroImage}
    alt=""
    widths={[768, 1280, 1920]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
  />
  <div
    class="absolute inset-0 bg-gradient-to-r from-night/95 via-night/85 to-slateDeep/55"
  >
  </div>
  <div
    class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-night to-transparent"
  >
  </div>

  <div
    class="container-page relative z-10 grid min-h-[calc(100vh-7rem)] items-center py-16 lg:grid-cols-[1.08fr_0.92fr]"
  >
    <div class="max-w-4xl">
      <p class="eyebrow hero-enter hero-enter-1 text-cyan-100">IA Para Todos LATAM</p>
      <h1 class="heading-xl hero-enter hero-enter-2">{heroContent.title}</h1>
      <p class="body-lg hero-enter hero-enter-3 mt-6 max-w-2xl">{heroContent.subtitle}</p>
      <p class="hero-enter hero-enter-4 mt-5 max-w-2xl text-base leading-7 text-slate-300 sm:text-lg">
        No se trata solo de aprender herramientas. Se trata de comprender cómo
        la IA impactará nuestra vida, nuestro trabajo y nuestra sociedad.
      </p>
      <div class="hero-enter hero-enter-5 mt-9 flex flex-wrap gap-3">
        <a class="btn-primary" href="#ecosistema">{heroContent.primaryCta}</a>
        <a class="btn-secondary" href={kidsHref}>{heroContent.secondaryCta}</a>
      </div>
      <div class="hero-enter hero-enter-6 mt-9 grid max-w-2xl gap-3 sm:grid-cols-3">
        {
          heroCards.map(({ label, Icon }) => (
            <div class="group flex items-center gap-3 rounded-2xl border border-cyan-100/15 bg-slate-900/60 px-4 py-4 text-sm font-semibold text-slate-100 backdrop-blur transition duration-300 hover:-translate-y-0.5 hover:border-cyan-200/40 hover:bg-slate-900/75">
              <span class="grid h-9 w-9 shrink-0 place-items-center rounded-xl bg-cyan-300/10 text-cyan-100 ring-1 ring-cyan-200/20 transition group-hover:bg-cyan-300/20 group-hover:text-cyan-50">
                <Icon size={18} stroke-width={1.8} />
              </span>
              <span>{label}</span>
            </div>
          ))
        }
      </div>
    </div>

    <div class="hero-enter hero-enter-5 mt-12 hidden lg:block">
      <div class="relative rounded-[2rem] border border-slate-400/20 bg-cardSurface/70 p-5 shadow-glow">
        <div
          class="absolute -left-3 -top-3 h-16 w-16 rounded-full bg-brandSky/12 blur-xl"
        >
        </div>
        <div class="rounded-[1.5rem] border border-cyan-100/10 bg-night/75 p-7">
          <p class="text-sm font-bold uppercase tracking-wide text-cyan-100">
            Enfoque
          </p>
          <p class="mt-5 text-3xl font-black leading-tight text-white">
            "La alfabetización en IA es una oportunidad para personas,
            comunidades e instituciones de toda Latinoamérica."
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
