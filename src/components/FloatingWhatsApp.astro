---
import { CONTACT } from "../data/site.js";
import { buildWhatsAppUrl } from "../data/automation.js";
import { MessagesSquare } from "lucide-astro";
---

<a
  class="fixed bottom-5 right-5 z-40 grid h-14 w-14 place-items-center rounded-2xl bg-emerald-500 text-white shadow-[0_0_45px_rgba(16,185,129,0.45)] transition hover:-translate-y-1"
  href={buildWhatsAppUrl(CONTACT.whatsappNumber, CONTACT.whatsappMessage)}
  target="_blank"
  rel="noreferrer"
  aria-label="Hablar por WhatsApp"
>
  <MessagesSquare class="h-7 w-7" />
</a>
