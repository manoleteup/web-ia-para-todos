---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  ArrowLeft,
  BookOpen,
  Compass,
  HeartHandshake,
  Lightbulb,
  MessageCircle,
  Paintbrush,
  Rocket,
  ShieldCheck,
  Sparkles,
  Star,
  Users,
  Wand2,
} from "lucide-astro";
import {
  amazonBookUrl,
  CONTACT,
  featuredKidsBook,
  kidsCharacters,
  kidsForFamilies,
  kidsLearningItems,
} from "../data/site.js";
import { absoluteUrl, withBase } from "../utils/url";
import ikoMiniImg from "../assets/kids/iko.webp";
import pixaMiniImg from "../assets/kids/pixa.webp";

const kidsCanonical = absoluteUrl(CONTACT.siteUrl, "/kids/");
const kidsOgImage = absoluteUrl(CONTACT.siteUrl, "/og-image.jpg");
const homeHref = withBase("/");
const homeContactHref = withBase("/#contacto");

// Tematización por personaje (slug, glow, accent y motif)
const characterThemes: Record<
  string,
  {
    slug: string;
    glow: string;
    accent: string;
    stageFrom: string;
    stageTo: string;
    motif: "stars" | "splashes" | "planets" | "circuit" | "glow" | "book";
  }
> = {
  Iko: {
    slug: "iko",
    glow: "rgba(56, 189, 248, 0.55)",
    accent: "#22d3ee",
    stageFrom: "#0c1b3a",
    stageTo: "#0e7490",
    motif: "stars",
  },
  Pixa: {
    slug: "pixa",
    glow: "rgba(244, 114, 182, 0.6)",
    accent: "#f472b6",
    stageFrom: "#3a0a3a",
    stageTo: "#9d174d",
    motif: "splashes",
  },
  Nova: {
    slug: "nova",
    glow: "rgba(168, 85, 247, 0.55)",
    accent: "#a78bfa",
    stageFrom: "#1e1b4b",
    stageTo: "#4c1d95",
    motif: "planets",
  },
  Bit: {
    slug: "bit",
    glow: "rgba(52, 211, 153, 0.55)",
    accent: "#34d399",
    stageFrom: "#022c22",
    stageTo: "#065f46",
    motif: "circuit",
  },
  Lucecita: {
    slug: "lucecita",
    glow: "rgba(253, 224, 71, 0.7)",
    accent: "#fde047",
    stageFrom: "#3a2a04",
    stageTo: "#a16207",
    motif: "glow",
  },
  Teo: {
    slug: "teo",
    glow: "rgba(125, 211, 252, 0.55)",
    accent: "#7dd3fc",
    stageFrom: "#0c1f3a",
    stageTo: "#1e3a8a",
    motif: "book",
  },
};

const tabTilts = ["-3deg", "2deg", "-2deg", "3deg", "-2deg", "2deg"];
const tabBackgrounds = [
  "linear-gradient(135deg, #cffafe, #e0f2fe)",
  "linear-gradient(135deg, #fce7f3, #fef3c7)",
  "linear-gradient(135deg, #ede9fe, #e0e7ff)",
  "linear-gradient(135deg, #d1fae5, #ccfbf1)",
  "linear-gradient(135deg, #fef9c3, #fef3c7)",
  "linear-gradient(135deg, #e0f2fe, #dbeafe)",
];

const learningIcons = [Lightbulb, Paintbrush, Compass, HeartHandshake, Users];
const familyIcons = [BookOpen, MessageCircle, Wand2, ShieldCheck];

const universeLines = [
  {
    title: "Nuevos cuentos",
    description:
      "Más historias para descubrir cómo la IA puede ayudar con claridad, propósito y amabilidad.",
    icon: BookOpen,
  },
  {
    title: "Actividades educativas",
    description:
      "Propuestas para imaginar, dibujar, preguntar y crear junto a los personajes del universo Kids.",
    icon: Paintbrush,
  },
  {
    title: "Recursos para familias y docentes",
    description:
      "Material acompañante para conversar sobre tecnología, creatividad y responsabilidad.",
    icon: Users,
  },
];
---

<BaseLayout
  title="IA Para Todos Kids LATAM | Cuentos e IA para niños"
  description="Cuentos, personajes y aventuras para que niños y niñas descubran la Inteligencia Artificial de forma creativa, segura y responsable."
  canonical={kidsCanonical}
  ogUrl={kidsCanonical}
  ogTitle="IA Para Todos Kids LATAM"
  ogDescription="Descubre Bit y la lucecita que ayuda, una aventura del universo IA Para Todos Kids para aprender IA desde la infancia."
  ogImage={kidsOgImage}
>
  <main class="kids-world-bg relative overflow-hidden">
    <!-- ============================================ -->
    <!-- 1. Header Kids — cápsula flotante -->
    <!-- ============================================ -->
    <div class="pointer-events-none sticky top-4 z-40 flex w-full justify-center px-4">
      <nav
        class="kids-header-capsule"
        aria-label="Navegación IA Para Todos Kids"
      >
        <a href={homeHref} class="kids-header-back" aria-label="Volver a IA Para Todos LATAM">
          <ArrowLeft size={14} />
          <span class="hidden sm:inline">Volver a IA Para Todos LATAM</span>
          <span class="sm:hidden">Volver</span>
        </a>
        <span class="kids-header-brand">
          <Sparkles size={14} class="text-amber-300" />
          <span class="hidden sm:inline">IA Para Todos Kids</span>
          <span class="sm:hidden">Kids</span>
        </span>
        <a
          href={amazonBookUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="kids-header-cta"
        >
          <BookOpen size={14} />
          <span class="hidden sm:inline">Ver cuento en Amazon</span>
          <span class="sm:hidden">Cuento</span>
        </a>
      </nav>
    </div>

    <!-- ============================================ -->
    <!-- 2. Hero interactivo — Portal al multiverso -->
    <!-- ============================================ -->
    <section class="container-page relative pt-6 pb-16 sm:pt-10 sm:pb-24">
      <div class="kids-hero-scene grid gap-8 p-6 sm:p-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-10 lg:p-14" data-kids-hero>
        <!-- Capas decorativas -->
        <div class="kids-stars-layer kids-stars-back" data-parallax="0.4" aria-hidden="true"></div>
        <div class="kids-stars-layer" data-parallax="0.9" aria-hidden="true"></div>

        <!-- Orbits (decoración intencional, no relleno) -->
        <div
          class="kids-orbit"
          style="width:520px;height:520px;right:-160px;top:-120px"
          data-parallax="0.3"
          aria-hidden="true"
        ></div>
        <div
          class="kids-orbit"
          style="width:280px;height:280px;right:-40px;top:60px;border-color:rgba(253,224,71,0.25)"
          data-parallax="0.5"
          aria-hidden="true"
        ></div>

        <!-- Glow portal detrás del libro -->
        <div
          class="kids-portal-glow"
          style="width:380px;height:380px;right:6%;top:30%"
          aria-hidden="true"
        ></div>

        <!-- Light trail conectando texto y portada -->
        <div
          class="kids-light-trail hidden lg:block"
          style="left:48%;top:55%;width:18%;transform:rotate(-8deg)"
          aria-hidden="true"
        ></div>

        <!-- Contenido textual -->
        <div class="relative z-10 flex flex-col justify-center" data-parallax="0.15">
          <p class="eyebrow border-fuchsia-300/40 bg-white/5 text-fuchsia-200">
            <Star size={12} class="fill-amber-300 text-amber-300" />
            IA Para Todos Kids LATAM
          </p>
          <h1 class="heading-lg max-w-2xl">
            Cuentos y personajes para descubrir la IA desde la infancia.
          </h1>
          <p class="mt-5 max-w-xl text-lg leading-8 text-cyan-50/95 sm:text-xl">
            Un universo educativo donde niños y niñas aprenden sobre
            inteligencia artificial a través de historias, personajes y
            aventuras llenas de imaginación.
          </p>
          <p class="mt-4 max-w-xl text-base leading-7 text-amber-100/90">
            Aprender IA no tiene que ser técnico: puede comenzar con una
            historia, una pregunta y una lucecita que ayuda.
          </p>

          <div class="mt-7 flex flex-wrap gap-3">
            <a
              class="kids-btn-primary"
              href={amazonBookUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              <BookOpen size={16} />
              Ver cuento en Amazon
            </a>
            <a class="kids-btn-secondary" href="#personajes">
              <Sparkles size={16} />
              Conocer personajes
            </a>
          </div>
        </div>

        <!-- Portada flotante + personajes mini -->
        <div class="relative z-10 mx-auto flex w-full max-w-md items-center justify-center">
          <div class="kids-floating-book relative" data-parallax="0.45">
            <div
              class="relative rounded-[2rem] border border-amber-200/40 bg-white/95 p-3 shadow-[0_30px_60px_rgba(123,44,191,0.45)]"
            >
              <Image
                src={featuredKidsBook.image}
                alt={`Portada del cuento ${featuredKidsBook.title}`}
                class="mx-auto h-[26rem] w-full rounded-[1.5rem] object-contain"
                widths={[240, 360, 480, 640]}
                sizes="(min-width: 1024px) 24rem, (min-width: 640px) 22rem, 70vw"
                quality={72}
                loading="eager"
                fetchpriority="high"
              />
            </div>
            <!-- Estrella sobre el libro -->
            <div
              class="absolute -right-4 -top-4 grid h-12 w-12 place-items-center rounded-full bg-amber-300 text-[#14002e] shadow-[0_8px_24px_rgba(253,224,71,0.55)]"
              aria-hidden="true"
            >
              <Sparkles size={20} />
            </div>
          </div>

          <!-- Mini personajes flotando alrededor -->
          <Image
            src={ikoMiniImg}
            alt=""
            aria-hidden="true"
            class="absolute -left-2 top-6 hidden h-16 w-16 object-contain lg:block"
            style="animation: kids-float 8s ease-in-out infinite;"
            data-parallax="0.6"
            widths={[96, 160]}
            sizes="96px"
            loading="eager"
          />
          <Image
            src={pixaMiniImg}
            alt=""
            aria-hidden="true"
            class="absolute -bottom-2 right-0 hidden h-20 w-20 object-contain lg:block"
            style="animation: kids-float 9s ease-in-out infinite;"
            data-parallax="0.7"
            widths={[96, 160]}
            sizes="96px"
            loading="eager"
          />
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- 3. Cuento destacado — editorial -->
    <!-- ============================================ -->
    <section id="cuento-destacado" class="section-pad bg-white">
      <div class="container-page">
        <div class="kids-story-panel grid items-center gap-10 p-8 sm:p-12 lg:grid-cols-[0.95fr_1.05fr]">
          <!-- Decoración intencional: glow Lucecita -->
          <div
            class="pointer-events-none absolute -left-10 top-1/2 h-40 w-40 -translate-y-1/2 rounded-full bg-amber-300/40 blur-3xl"
            aria-hidden="true"
          ></div>
          <div
            class="pointer-events-none absolute right-10 top-10 text-fuchsia-400/40"
            aria-hidden="true"
          >
            <Sparkles size={22} />
          </div>

          <!-- Portada -->
          <div class="relative mx-auto w-full max-w-sm">
            <div
              class="absolute -inset-3 -z-10 rounded-[2.25rem] bg-gradient-to-br from-amber-200/50 via-fuchsia-200/40 to-cyan-200/40 blur-2xl"
              aria-hidden="true"
            ></div>
            <div
              class="relative rounded-[2rem] border border-fuchsia-200/60 bg-white p-4 shadow-[0_24px_48px_rgba(123,44,191,0.18)]"
            >
              <Image
                src={featuredKidsBook.image}
                alt={`Portada del cuento ${featuredKidsBook.title}`}
                class="mx-auto h-[25rem] w-full rounded-[1.4rem] object-contain"
                widths={[240, 360, 480, 640]}
                sizes="(min-width: 1024px) 22rem, (min-width: 640px) 20rem, 70vw"
                quality={75}
                loading="lazy"
              />
            </div>
          </div>

          <!-- Texto editorial -->
          <div class="relative">
            <span class="kids-story-tag">
              <BookOpen size={14} />
              Cuento destacado
            </span>
            <h2 class="mt-4 text-3xl font-black leading-tight text-[#1a0440] sm:text-4xl lg:text-5xl">
              {featuredKidsBook.title}
            </h2>
            <p class="mt-3 text-lg font-semibold text-fuchsia-700">
              {featuredKidsBook.subtitle}
            </p>
            <p class="mt-5 text-base leading-8 text-slate-700 sm:text-lg">
              {featuredKidsBook.description}
            </p>

            <ul class="mt-7 grid gap-3 sm:grid-cols-2">
              <li class="flex items-start gap-3 rounded-2xl border border-fuchsia-100 bg-white/80 p-3">
                <span class="grid h-9 w-9 place-items-center rounded-xl bg-fuchsia-100 text-fuchsia-700">
                  <Sparkles size={16} />
                </span>
                <div>
                  <p class="text-xs font-bold uppercase tracking-wide text-fuchsia-700">Formato</p>
                  <p class="text-sm font-semibold text-slate-800">Cuento digital</p>
                </div>
              </li>
              <li class="flex items-start gap-3 rounded-2xl border border-cyan-100 bg-white/80 p-3">
                <span class="grid h-9 w-9 place-items-center rounded-xl bg-cyan-100 text-cyan-700">
                  <BookOpen size={16} />
                </span>
                <div>
                  <p class="text-xs font-bold uppercase tracking-wide text-cyan-700">Plataforma</p>
                  <p class="text-sm font-semibold text-slate-800">{featuredKidsBook.platform}</p>
                </div>
              </li>
              <li class="flex items-start gap-3 rounded-2xl border border-amber-100 bg-white/80 p-3">
                <span class="grid h-9 w-9 place-items-center rounded-xl bg-amber-100 text-amber-700">
                  <HeartHandshake size={16} />
                </span>
                <div>
                  <p class="text-xs font-bold uppercase tracking-wide text-amber-700">Edad sugerida</p>
                  <p class="text-sm font-semibold text-slate-800">{featuredKidsBook.age}</p>
                </div>
              </li>
              <li class="flex items-start gap-3 rounded-2xl border border-violet-100 bg-white/80 p-3">
                <span class="grid h-9 w-9 place-items-center rounded-xl bg-violet-100 text-violet-700">
                  <MessageCircle size={16} />
                </span>
                <div>
                  <p class="text-xs font-bold uppercase tracking-wide text-violet-700">Narrado por</p>
                  <p class="text-sm font-semibold text-slate-800">{featuredKidsBook.narrator}</p>
                </div>
              </li>
            </ul>

            <a
              class="mt-8 inline-flex min-h-12 items-center justify-center gap-2 rounded-full bg-gradient-to-r from-amber-400 to-fuchsia-500 px-6 py-3 text-sm font-extrabold text-[#14002e] shadow-[0_12px_28px_rgba(253,224,71,0.4)] transition hover:-translate-y-0.5"
              href={amazonBookUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              <BookOpen size={16} />
              Ver cuento en Amazon
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- 4. Selector interactivo de personajes -->
    <!-- ============================================ -->
    <section id="personajes" class="section-pad kids-world-bg relative overflow-hidden">
      <!-- Decoración cosmica intencional -->
      <div class="kids-stars-layer" aria-hidden="true"></div>
      <div
        class="pointer-events-none absolute -left-24 top-32 h-72 w-72 rounded-full bg-fuchsia-500/15 blur-3xl"
        aria-hidden="true"
      ></div>
      <div
        class="pointer-events-none absolute right-0 bottom-32 h-80 w-80 rounded-full bg-cyan-400/15 blur-3xl"
        aria-hidden="true"
      ></div>

      <div class="container-page relative z-10">
        <div class="max-w-3xl">
          <p class="eyebrow border-fuchsia-300/40 bg-white/5 text-fuchsia-200">
            <Star size={12} class="fill-amber-300 text-amber-300" />
            Personajes
          </p>
          <h2 class="heading-lg text-white">Personajes del universo IA Kids</h2>
          <p class="mt-5 text-base leading-8 text-cyan-50/95 sm:text-lg">
            Cada personaje acompaña una forma distinta de aprender: preguntar,
            imaginar, crear, resolver y usar la tecnología con responsabilidad.
          </p>
        </div>

        <div class="kids-character-selector mt-12" data-kids-character-selector>
          <!-- Stage -->
          <div class="kids-character-stage" data-character-stage>
            {
              kidsCharacters.map((character, i) => {
                const theme = characterThemes[character.name] ?? characterThemes.Iko;
                const isFirst = i === 0;
                return (
                  <article
                    id={`panel-${theme.slug}`}
                    class="kids-char-panel"
                    data-character-panel={theme.slug}
                    data-active={isFirst ? "true" : "false"}
                    data-stage-from={theme.stageFrom}
                    data-stage-to={theme.stageTo}
                    role="tabpanel"
                    aria-labelledby={`tab-${theme.slug}`}
                    tabindex="0"
                    style={`--char-glow: ${theme.glow}; --char-accent: ${theme.accent};`}
                  >
                    <div class="kids-char-image-wrap">
                      {character.image ? (
                        <Image
                          src={character.image}
                          alt={`Personaje ${character.name} de IA Para Todos Kids`}
                          widths={[200, 320, 480]}
                          sizes="(min-width: 1024px) 14rem, (min-width: 640px) 12rem, 50vw"
                          loading="lazy"
                        />
                      ) : (
                        <div
                          class="relative grid h-full w-full place-items-center rounded-full"
                          style={`background: radial-gradient(circle, ${theme.accent} 0%, transparent 65%);`}
                          aria-hidden="true"
                        >
                          <Sparkles size={48} class="text-white" />
                        </div>
                      )}
                    </div>
                    <h3 class="kids-char-name" aria-label={character.name}>
                      {character.name}
                    </h3>
                    <p class="kids-char-role">{character.role}</p>
                    <p class="kids-char-desc">{character.description}</p>
                  </article>
                );
              })
            }
          </div>

          <!-- Tabs -->
          <div class="kids-character-tabs-column">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-fuchsia-200">
              Elige un personaje
            </p>
            <div
              class="kids-character-tabs"
              role="tablist"
              aria-label="Selector de personajes"
            >
              {
                kidsCharacters.map((character, i) => {
                  const theme = characterThemes[character.name] ?? characterThemes.Iko;
                  const isFirst = i === 0;
                  return (
                    <button
                      type="button"
                      id={`tab-${theme.slug}`}
                      class="kids-character-tab"
                      data-character-tab={theme.slug}
                      data-active={isFirst ? "true" : "false"}
                      role="tab"
                      aria-selected={isFirst ? "true" : "false"}
                      aria-controls={`panel-${theme.slug}`}
                      tabindex={isFirst ? 0 : -1}
                      style={`--tilt: ${tabTilts[i] ?? "0deg"}; --char-accent: ${theme.accent}; background: ${tabBackgrounds[i] ?? "#fff"};`}
                    >
                      {character.image ? (
                        <Image
                          src={character.image}
                          alt=""
                          aria-hidden="true"
                          widths={[64, 96, 128]}
                          sizes="64px"
                          loading="lazy"
                        />
                      ) : (
                        <div
                          class="grid h-14 w-14 place-items-center rounded-full"
                          style={`background: ${theme.accent};`}
                          aria-hidden="true"
                        >
                          <Sparkles size={22} class="text-white" />
                        </div>
                      )}
                      <span class="kids-character-tab-label">{character.name}</span>
                    </button>
                  );
                })
              }
            </div>
            <!-- <p class="kids-character-hint">
              <span class="hidden lg:inline">Usa</span>
              <kbd aria-label="Flecha izquierda">←</kbd>
              <kbd aria-label="Flecha derecha">→</kbd>
              <span>o haz clic para conocer a cada personaje</span>
            </p> -->
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- 5. Camino de aprendizaje -->
    <!-- ============================================ -->
    <section
      id="aprendizaje"
      class="section-pad relative overflow-hidden bg-gradient-to-b from-sky-50 via-cyan-50 to-fuchsia-50"
    >
      <!-- Decoración intencional: estrellas en cielo -->
      <div
        class="pointer-events-none absolute left-1/4 top-12 text-amber-400/70"
        aria-hidden="true"
      >
        <Star size={26} class="fill-amber-300" stroke-width={1.5} />
      </div>
      <div
        class="pointer-events-none absolute right-1/3 top-32 text-fuchsia-400/60"
        aria-hidden="true"
      >
        <Sparkles size={22} />
      </div>
      <div
        class="pointer-events-none absolute right-12 top-20 text-cyan-400/60"
        aria-hidden="true"
      >
        <Star size={18} class="fill-cyan-300" stroke-width={1.5} />
      </div>

      <div class="container-page relative">
        <div class="max-w-3xl">
          <p class="eyebrow border-cyan-300/60 bg-cyan-100 text-cyan-800">
            <Compass size={12} />
            Camino de aprendizaje
          </p>
          <h2 class="heading-lg text-[#1a0440]">
            Una historia para aprender IA sin tecnicismos
          </h2>
          <p class="mt-5 text-base leading-8 text-slate-700 sm:text-lg">
            En esta aventura, los niños descubren que la IA puede ser una ayuda
            cuando se usa con claridad, propósito y amabilidad.
          </p>
        </div>

        <ol class="kids-learning-path mt-14" aria-label="Pasos del camino de aprendizaje">
          {
            kidsLearningItems.map((item, i) => {
              const Icon = learningIcons[i] ?? Sparkles;
              return (
                <li class="kids-learning-node">
                  <span class="kids-node-icon" aria-hidden="true">
                    <Icon size={18} />
                  </span>
                  <span class="kids-node-number">{i + 1}</span>
                  <h3 class="text-lg font-extrabold text-[#1a0440]">{item.title}</h3>
                  <p class="mt-2 text-sm leading-6 text-slate-700">{item.description}</p>
                </li>
              );
            })
          }
        </ol>

        <!-- Lucecita guía visual al final -->
        <div class="mt-12 flex flex-col items-center gap-4 rounded-3xl border border-amber-200 bg-amber-50/80 p-5 text-center sm:flex-row sm:text-left">
          <div
            class="relative grid h-14 w-14 shrink-0 place-items-center rounded-full bg-amber-300"
            aria-hidden="true"
            style="animation: kids-glow-pulse 4s ease-in-out infinite;"
          >
            <div
              class="absolute inset-[-10px] rounded-full bg-amber-300/40 blur-md"
            ></div>
            <Sparkles size={22} class="relative text-amber-800" />
          </div>
          <p class="text-sm font-semibold text-amber-900 sm:text-base">
            Lucecita acompaña cada paso: una IA que ayuda cuando se usa con
            claridad, propósito y amabilidad.
          </p>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- 6. Para familias y educadores -->
    <!-- ============================================ -->
    <section id="familias" class="section-pad relative bg-white">
      <div
        class="pointer-events-none absolute -left-10 top-20 h-40 w-40 rounded-full bg-fuchsia-100 blur-3xl"
        aria-hidden="true"
      ></div>
      <div
